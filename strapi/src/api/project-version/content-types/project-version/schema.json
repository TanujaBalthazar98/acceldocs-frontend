{
  "kind": "collectionType",
  "collectionName": "project_versions",
  "info": {
    "singularName": "project-version",
    "pluralName": "project-versions",
    "displayName": "Project Version"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "versions"
    },
    "name": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true },
    "is_default": { "type": "boolean", "default": false },
    "is_published": { "type": "boolean", "default": false },
    "semver_major": { "type": "integer", "default": 0 },
    "semver_minor": { "type": "integer", "default": 0 },
    "semver_patch": { "type": "integer", "default": 0 },
    "topics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::topic.topic",
      "mappedBy": "project_version"
    },
    "documents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::document.document",
      "mappedBy": "project_version"
    }
  }
}

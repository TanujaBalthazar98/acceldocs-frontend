{
  "kind": "collectionType",
  "collectionName": "domains",
  "info": {
    "singularName": "domain",
    "pluralName": "domains",
    "displayName": "Domain"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "domains"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project"
    },
    "domain": { "type": "string", "required": true },
    "domain_type": {
      "type": "enumeration",
      "enum": ["custom", "subdomain"],
      "default": "custom"
    },
    "is_primary": { "type": "boolean", "default": false },
    "is_verified": { "type": "boolean", "default": false },
    "verification_token": { "type": "string" },
    "ssl_status": {
      "type": "enumeration",
      "enum": ["pending", "provisioning", "active", "failed"],
      "default": "pending"
    }
  }
}

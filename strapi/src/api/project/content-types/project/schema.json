{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "string" },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "projects"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project.project",
      "mappedBy": "parent"
    },
    "visibility": {
      "type": "enumeration",
      "enum": ["internal", "external", "public"],
      "default": "internal"
    },
    "is_published": { "type": "boolean", "default": false },
    "drive_folder_id": { "type": "string" },
    "drive_parent_id": { "type": "string" },
    "created_by": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "show_version_switcher": { "type": "boolean", "default": true },
    "versions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project-version.project-version",
      "mappedBy": "project"
    },
    "topics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::topic.topic",
      "mappedBy": "project"
    },
    "documents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::document.document",
      "mappedBy": "project"
    }
  }
}
